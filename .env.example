# Hooten Young Sales — environment variables
#
# Real values are NEVER committed to this file:
#   • Local dev:  copy this to `.env.local` (gitignored) and fill in values.
#   • Cloud Run: values come from per-environment GitHub Actions secrets
#                or the Cloud Run service config directly.

# ---------------------------------------------------------------
# Database
# ---------------------------------------------------------------

# Async Postgres URL.
#   Local dev (via Cloud SQL Auth Proxy or IP allowlist):
#     postgresql+asyncpg://user:pass@localhost:5432/hysales
#   Cloud Run (via attached Cloud SQL unix socket):
#     postgresql+asyncpg://user:pass@/hysales?host=/cloudsql/<connection-name>
DATABASE_URL=postgresql+asyncpg://postgres:jgXCVP55r1VpTHJYrE2EeP70Xr5j@db-dev.35.222.133.141.nip.io:5432/appdb?ssl=require

# ---------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------

# Environment name: local | dev | prod
APP_ENV=local

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------
# Authentication / JWT
# ---------------------------------------------------------------

# HMAC signing secret for JWT access tokens. REQUIRED.
# Generate a fresh value per environment with:
#   openssl rand -hex 64
# Rotating this invalidates every existing token (forces re-login).
# Different value per env — NEVER share between local/dev/prod.
JWT_SECRET=

# JWT signing algorithm. Default HS256 (HMAC-SHA256) is correct for
# a single-issuer setup. Leave unless you switch to RS256.
JWT_ALGORITHM=HS256

# Access token lifetime in hours. No refresh tokens — user re-logs
# in after this expires. 24h matches a workday's worth of usage.
JWT_ACCESS_TTL_HOURS=24

# ---------------------------------------------------------------
# Password reset / set-password
# ---------------------------------------------------------------

# Lifetime of password-reset and admin-created-account "set password"
# tokens. 24h is the standard balance between security and UX.
PASSWORD_RESET_TTL_HOURS=24

# Frontend URL where reset emails point. The plaintext token is
# appended as ?token=<value>. Use the dashboard URL for this env:
#   local: http://localhost:5173/auth/reset-password
#   dev:   https://dashboard-dev.hootenyoung.com/auth/reset-password
#   prod:  https://dashboard.hootenyoung.com/auth/reset-password
FRONTEND_RESET_URL=http://localhost:5173/auth/reset-password

# ---------------------------------------------------------------
# Tooling / MCP
# ---------------------------------------------------------------

# GitHub personal access token (scope: repo). Used by the github MCP server.
# Generate at https://github.com/settings/tokens
GITHUB_TOKEN=
