# Hooten Young Analytics — environment variables
#
# In production, all secrets come from GCP Secret Manager — this file is for local dev only.
#
# How to use:
#   1. Copy this file to `.env.local` (local dev) — `.env.local` is gitignored.
#   2. In production (Cloud Run), set the same vars from Secret Manager via deploy config.
#   3. Never commit real values. This file is only for documenting which vars exist.
#
# ---------------------------------------------------------------
# Database
# ---------------------------------------------------------------

# Postgres (async). Format: postgresql+asyncpg://user:pass@host:5432/dbname
# This is the SHARED database — coordinate with hooten-young-dashboard before
# changing schema. Vector columns require the pgvector extension to be enabled.
DATABASE_URL=

# ---------------------------------------------------------------
# GCP
# ---------------------------------------------------------------

# GCP project ID (e.g. hooten-young-analytics or shared HY project)
GCP_PROJECT_ID=

# Region for Cloud Run / Cloud SQL (e.g. us-central1)
GCP_REGION=

# GCS bucket for raw scraped media (videos, images, thumbnails)
GCS_BUCKET_RAW_MEDIA=

# Path to local service-account JSON for dev only. NEVER commit the JSON file.
# In production this is unset; Cloud Run uses the attached service account.
# GOOGLE_APPLICATION_CREDENTIALS=./.secrets/dev-service-account.json

# ---------------------------------------------------------------
# Scraping providers
# ---------------------------------------------------------------

# Apify — default scraping provider. https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# ---------------------------------------------------------------
# AI providers
# ---------------------------------------------------------------

# Anthropic — Claude API for reasoning, summarization, pattern descriptions.
ANTHROPIC_API_KEY=

# Embeddings provider toggle: "openai" | "vertex"
EMBEDDINGS_PROVIDER=openai

# OpenAI API key — only required if EMBEDDINGS_PROVIDER=openai
# OPENAI_API_KEY=

# ---------------------------------------------------------------
# Tooling / MCP
# ---------------------------------------------------------------

# GitHub personal access token for the github MCP server (scopes: repo, read:org).
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ---------------------------------------------------------------
# Runtime config
# ---------------------------------------------------------------

# App environment: local | staging | production
APP_ENV=local

# Logging level
LOG_LEVEL=INFO
